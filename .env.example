# The API uses only local paths and self-hosted services by default.
KNOWLEDGEOS_APP_NAME=KnowledgeOS
KNOWLEDGEOS_ENVIRONMENT=development
KNOWLEDGEOS_UPLOAD_DIRECTORY=backend/data/uploads
KNOWLEDGEOS_MAX_UPLOAD_SIZE_BYTES=104857600
KNOWLEDGEOS_DATABASE_PATH=backend/data/knowledgeos.db
KNOWLEDGEOS_OLLAMA_BASE_URL=http://localhost:11434
KNOWLEDGEOS_OLLAMA_CHAT_MODEL=llama3.2
KNOWLEDGEOS_RETRIEVAL_LIMIT=6
